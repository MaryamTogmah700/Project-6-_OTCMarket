			</fk>
			<fk name="fk_Fact_OTC_Market_Dim_Tier" to_schema="lgl" to_table="Dim_Tier" type="NonIdentifying" mandatory="y" cardinality="OneMore" range_from="0" range_to="0" />
			<fk name="fk_Fact_OTC_Market_Dim_Security" to_schema="lgl" to_table="Dim_Security" type="NonIdentifying" mandatory="y" cardinality="OneMore" range_from="0" range_to="0" >
				<fk_column name="SecurityKey" pk="SecurityKey" />
			</fk>
			<fk name="fk_Fact_OTC_Market_Dim_SecurityStatus" to_schema="lgl" to_table="Dim_SecurityStatus" type="NonIdentifying" mandatory="y" cardinality="OneMore" range_from="0" range_to="0" >
				<fk_column name="StatusKey" pk="StatusKey" />
			</fk>
		</table>
	</schema>
